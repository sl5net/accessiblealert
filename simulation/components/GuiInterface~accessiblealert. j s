// 1. Die Suchfunktion definieren
GuiInterface.prototype.AccessibleAlert_FindNearestResource = function(player, data)
{
    let selectedEnts = data.entities;
    let resourceType = data.resourceType; // "wood", "stone", "metal", "food"

    if (!selectedEnts || selectedEnts.length === 0)
        return null;

    // Berechne die durchschnittliche Position der ausgewaehlten Einheiten
    let totalX = 0;
    let totalY = 0;
    let count = 0;

    for (let ent of selectedEnts)
    {
        let cmpPosition = Engine.QueryInterface(ent, IID_Position);
        if (cmpPosition && cmpPosition.IsInWorld())
        {
            let pos = cmpPosition.GetPosition2D();
            totalX += pos.x;
            totalY += pos.y;
            count++;
        }
    }

    if (count === 0)
        return null;

    let avgX = totalX / count;
    let avgY = totalY / count;

    let bestEnt = null;
    let bestDist = Infinity;



    let cmpRangeManager = Engine.QueryInterface(SYSTEM_ENTITY, IID_RangeManager);
    if (cmpRangeManager)
    {
        // Alle unberührten Ressourcen gehören dem Gaia-Spieler 0 [2.4.1, 2.4.2]
        let gaiaEntities = cmpRangeManager.GetEntitiesByPlayer(0);

        for (let ent of gaiaEntities)
        {
            let cmpResourceSupply = Engine.QueryInterface(ent, IID_ResourceSupply);
            if (!cmpResourceSupply)
                continue;

            let type = cmpResourceSupply.GetType();
            if (type && type.generic === resourceType)
            {
                let cmpPosition = Engine.QueryInterface(ent, IID_Position);
                if (cmpPosition && cmpPosition.IsInWorld())
                {
                    let pos = cmpPosition.GetPosition2D();
                    let dist = (pos.x - avgX) * (pos.x - avgX) + (pos.y - avgY) * (pos.y - avgY);

                    // Prüfen, ob die Ressource im Umkreis von 150 Metern liegt (150 * 150 = 22500)
                    if (dist < 22500 && dist < bestDist)
                    {
                        bestDist = dist;
                        bestEnt = ent;
                    }
                }
            }
        }
    }




